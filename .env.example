# ── Flask ────────────────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Set to true only during local development — NEVER in production
FLASK_DEBUG=false

# ── MySQL connection (fill in your Aiven details) ────────────────────────────
MYSQL_HOST=your-service.aivencloud.com
MYSQL_PORT=12345
MYSQL_USER=avnadmin
MYSQL_PASSWORD=your-aiven-password
MYSQL_DATABASE=defaultdb

# ── SSL (required for Aiven, leave blank for local dev) ──────────────────────
# Path to the CA certificate downloaded from Aiven console.
# Commit the cert to certs/ca.pem and set this value on Render.
MYSQL_SSL_CA=certs/ca.pem
